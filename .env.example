# Isi user_id (pisahkan koma) untuk restrict: DEBUG_ALLOWED_USERS=123456,789012
DEBUG_ALLOWED_USERS=

# ── Word Config paths ─────────────────────────
SCOPE_CONFIG_PATH=word_config/scope_config.ini
REWRITER_CONFIG_PATH=word_config/rewriter_config.ini
