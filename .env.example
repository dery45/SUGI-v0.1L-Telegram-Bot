# ── API Keys ──────────────────────────────────
PERENUAL_API_KEY=""

# ── Database ──────────────────────────────────
PORT=3000
MONGO_URI=""

# ── ChromaDB ──────────────────────────────────
CHROMA_HOST=
CHROMA_PORT=

# ── Ollama Models ─────────────────────────────
EMBED_MODEL=mxbai-embed-large
LLM_MODEL=sugi-v0.1L
UTILITY_MODEL=qwen2.5:1.5b

# ── Telegram Bot ──────────────────────────────
TELEGRAM_BOT_TOKEN=""
